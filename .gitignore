# ===========================================================================
# Terraform
# ===========================================================================

# Local .terraform directories (downloaded providers & modules)
**/.terraform/

# Terraform lock files — commit these to pin provider versions
!.terraform.lock.hcl

# Terraform state files — NEVER commit state (contains secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars.json
# Keep .tfvars example files but ignore local overrides
terraform.tfvars
!*.tfvars.example
!environments/*.tfvars

# Terraform plan output files (may contain sensitive values)
*.tfplan
*.plan

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ===========================================================================
# Secrets & credentials — never commit these
# ===========================================================================
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*credentials*.json
*service-account*.json
*sa-key*.json
.env
.env.*
secrets/
secret/

# ===========================================================================
# macOS
# ===========================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ===========================================================================
# Editor / IDE
# ===========================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ===========================================================================
# OS / misc
# ===========================================================================
Thumbs.db
*.log
